<?php namespace ProcessWire;

/**
 * ProcessWire Upgrade Check
 *
 * Automatically checks for core and installed module upgrades at routine intervals.
 * Also provides the API functions for repository info used by ProcessWireUpgrade module.
 *
 * ProcessWire
 * Copyright (C) 2021 by Ryan Cramer
 * Licensed under MPL 2.0
 *
 * https://processwire.com
 *
 * @property bool $useLoginHook
 * @property bool $useModuleInfoRepo
 *
 */

class ProcessWireUpgradeCheck extends WireData implements Module {

	/**
	 * Return information about this module
	 *
	 * @return array<string, mixed>
	 */
	public static function getModuleInfo(): array {
		return [
			'title' => 'Upgrades Checker',
			'summary' => 'Automatically checks for core and installed module upgrades at routine intervals.',
			'version' => 11,
			'autoload' => 'template=admin',
			'singular' => true,
			'repo' => 'https://github.com/matjazpotocnik/ProcessWireUpgrade',
			'href' => 'https://processwire.com/talk/topic/7525-module-processwire-core-upgrade/',
			'author' => 'Ryan Cramer, Matjaž Potočnik, Claude Sonnet 4.6',
			'requires' => ['ProcessWire>=3.0.246', 'PHP>=8.2', 'ProcessWireUpgrade'],
			'icon' => 'coffee',
		];
	}

	const TIMEOUT = 4.5;

	/**
	 * Repository information indexed by branch
	 *
	 * @var array<string, array{branchesURL: string, zipURL: string, versionURL: string, tagsURL: string, devzipURL: string}>
	 *
	 */
	protected array $repos = [];

	/**
	 * Construct
	 *
	 */
	public function __construct() {
		$this->set('useLoginHook', 1);
		$this->set('useModuleInfoRepo', 0);
		$this->repos = [
			'main' => [
				'branchesURL' => 'https://api.github.com/repos/processwire/processwire/branches',
				'zipURL'      => 'https://github.com/processwire/processwire/archive/{branch}.zip',
				'versionURL'  => 'https://raw.githubusercontent.com/processwire/processwire/{branch}/wire/core/ProcessWire.php',
				'tagsURL'     => 'https://api.github.com/repos/processwire/processwire/tags',
				'devzipURL'   => 'https://github.com/processwire/processwire/archive/{sha}.zip',
			],
		];
	}

	/**
	 * Initialize and perform access checks
	 *
	 */
	public function init(): void {
		if($this->useLoginHook) {
			$this->session->addHookAfter('login', $this, 'loginHook');
		}
	}

	/**
	 * Check for upgrades at login (superuser only)
	 *
	 * @param null|HookEvent $e
	 *
	 */
	public function loginHook($e = null): void {

		//if($e) {} // ignored HookEvent
		if(!$this->user->isSuperuser()) return; // only show messages to superuser

		$moduleVersions = [];
		$cache = $this->cache;
		$cacheName = $this->className() . "_loginHook";
		$cacheData = $cache ? $cache->get($cacheName) : null;

		// Note: this line previously overwrote $cache (the WireCache object) — fixed to use $cacheData
		if(!empty($cacheData) && is_string($cacheData)) $cacheData = json_decode($cacheData, true);
		$branches = $this->getCoreBranches(false);
		if(is_array($cacheData) && isset($cacheData['branches']) && is_array($cacheData['branches'])) {
			$branches = $cacheData['branches'];
		}
		if(empty($branches)) return;
		if(!isset($branches['master']) || !is_array($branches['master']) || !isset($branches['master']['version']) || !is_string($branches['master']['version'])) return;
		$master = $branches['master'];
		$branch = null;
		$new = version_compare($master['version'], $this->config->version);

		if($new > 0) {
			// master is newer than current
			$branch = $master;
		} elseif($new < 0 && isset($branches['dev'])) {
			// we will assume dev branch
			$dev = $branches['dev'];
			if(is_array($dev) && ($devVersion = $this->toString($dev['version'] ?? '')) !== '') {
				$new = version_compare($devVersion, $this->config->version);
				if($new > 0) $branch = $dev;
			}
		}

		if(is_array($branch)) {
			/** @var array<string, mixed> $branch */
			$branchName = $this->toString($branch['name'] ?? '');
			$branchVersion = $this->toString($branch['version'] ?? '');
			$versionStr = trim($branchName . ' ' . $branchVersion);
			$msg = $this->_('A ProcessWire core upgrade is available') . " ($versionStr)";
			$this->message($msg);
		} else {
			$this->message($this->_('Your ProcessWire core is up-to-date'));
		}

		if($this->config->moduleServiceKey) {
			$n = 0;
			if(!is_array($cacheData) || empty($cacheData['moduleVersions'])) {
				// Skip GitHub SHA checks on login — those run on the upgrade page only
				$moduleVersions = $this->getModuleVersions(true, false, false);
			} else {
				$moduleVersions = is_array($cacheData['moduleVersions']) ? $cacheData['moduleVersions'] : [];
			}
			/** @var array<string, array<string, mixed>> $moduleVersions */
			foreach($moduleVersions as $name => $info) {
				$msg = sprintf($this->_('An upgrade for %s is available'), $name) . " ({$this->toString($info['remote'] ?? '')})";
				$this->message($msg);
				$n++;
			}
			if(!$n) $this->message($this->_('Your modules are up-to-date'));
		}

		if($cache) {
			$cacheData = [
				'branches' => $branches,
				'moduleVersions' => $moduleVersions
			];
			$cache->save($cacheName, $cacheData, 43200); // 43200=12hr
		}
	}

	/**
	 * Get versions of core or modules
	 *
	 * @param bool $refresh
	 * @return array of array(
	 * 	'ModuleName' => array(
	 *		'title' => 'Module Title',
	 *		'local' => '1.2.3', // current installed version
	 * 		'remote' => '1.2.4', // directory version available, or boolean false if not found in directory
	 * @return array<string, array{
	 *   title: string,
	 *   icon: string,
	 *   local: string,
	 *   remote: string|false,
	 *   new: int,
	 *   author: string,
	 *   href: string,
	 *   summary: string,
	 *   urls?: array<string, string>,
	 *   branch?: string,
	 *   requiresVersions?: array<string, array{0: string, 1: string}>,
	 *   installs?: array<int, string>,
	 *   installer?: string,
	 *   pro?: bool,
	 *   sha?: string
	 * }>
	 *
	 */
	public function getVersions(bool $refresh = false) {

		$versions = [];
		$branches = $this->getCoreBranches(false, $refresh);

		foreach($branches as $branchName => $branch) {
			$name = "ProcessWire $branchName";
			$new = version_compare($branch['version'], $this->config->version);
			// Bleeding-edge branch: compare current SHA against the last installed SHA;
			// only offer as an upgrade when the SHA has actually changed.
			if(isset($branch['sha'])) {
				$installedSha = $this->cache->get('ProcessWireUpgrade_installedDevSha');
				if($installedSha && $installedSha === $branch['sha']) {
					$new = 0; // same SHA as last install — up-to-date
				} elseif($new >= 0) {
					$new = 1; // different (or never installed) SHA — offer upgrade
				}
			}
			$remote = $branch['version'];
			if(isset($branch['sha'])) $remote .= ' (' . substr($branch['sha'], 0, 7) . ')';
			$versions[$name] = [
				'title' => "ProcessWire Core ($branch[title])",
				'icon' => 'microchip',
				'local' => $this->config->version,
				'remote' => $remote,
				'new' => $new,
				'branch' => $branch['name'],
				'author' => 'ProcessWire',
				'href' => '',
				'summary' => '',
				'urls' => $branch['urls'] ?? []
			];
		}

		if($this->config->moduleServiceKey) {
			foreach($this->getModuleVersions(false, $refresh) as $name => $info) {
				$versions[$name] = $info;
			}
		}

		return $versions;
	}

	/**
	 * Return normalized, type-safe module info for the given module name.
	 *
	 * @return array{
	 *   core: bool,
	 *   title: string,
	 *   summary: string,
	 *   icon: string,
	 *   author: string,
	 *   href: string,
	 *   repo: string,
	 *   versionStr: string,
	 *   requiresVersions: array<string, array{0: string, 1: string}>,
	 *   installs: array<int, string>
	 * }
	 */
	protected function getModuleInfoVerbose(string $name): array {
		$raw = $this->modules->getModuleInfoVerbose($name);
		/** @var array<string, mixed> $raw */

		$requiresVersions = [];
		$rawRequires = $raw['requiresVersions'] ?? [];
		if(is_array($rawRequires)) {
			foreach($rawRequires as $requiresName => $requiresPair) {
				if(!is_array($requiresPair)) continue;
				$reqName = $this->toString($requiresName);
				if($reqName === '') continue;
				$requiresVersions[$reqName] = [
					$this->toString($requiresPair[0] ?? ''),
					$this->toString($requiresPair[1] ?? ''),
				];
			}
		}

		$installs = [];
		$rawInstalls = $raw['installs'] ?? [];
		if(is_array($rawInstalls)) {
			foreach($rawInstalls as $installName) {
				$installName = $this->toString($installName);
				if($installName !== '') $installs[] = $installName;
			}
		}

		return [
			'core'             => !empty($raw['core']),
			'title'            => $this->toString($raw['title'] ?? ''),
			'summary'          => $this->toString($raw['summary'] ?? ''),
			'icon'             => $this->toString($raw['icon'] ?? ''),
			'author'           => $this->toString($raw['author'] ?? ''),
			'href'             => $this->toString($raw['href'] ?? ''),
			'repo'             => $this->toString($raw['repo'] ?? ''),
			'versionStr'       => $this->toString($raw['versionStr'] ?? ''),
			'requiresVersions' => $requiresVersions,
			'installs'         => $installs,
		];
	}

	/**
	 * Return normalized, type-safe branch info for the given raw branch data.
	 *
	 * @param array<string, mixed> $raw
	 * @return array{
	 *   name: string,
	 *   title: string,
	 *   zipURL: string,
	 *   devzipURL: string,
	 *   version: string,
	 *   versionURL: string,
	 *   urls: array{repo: string, download: string, support: string},
	 *   sha?: string
	 * }
	 */
	protected function normalizeBranch(array $raw): array {
		$urls = $raw['urls'] ?? [];
		if (!is_array($urls)) $urls = [];

		$normalized = [
			'name'      => $this->toString($raw['name'] ?? ''),
			'title'     => $this->toString($raw['title'] ?? ''),
			'zipURL'    => $this->toString($raw['zipURL'] ?? ''),
			'devzipURL' => $this->toString($raw['devzipURL'] ?? ''),
			'version'   => $this->toString($raw['version'] ?? ''),
			'versionURL' => $this->toString($raw['versionURL'] ?? ''),
			'urls'      => [
				'repo'     => $this->toString($urls['repo'] ?? ''),
				'download' => $this->toString($urls['download'] ?? ''),
				'support'  => $this->toString($urls['support'] ?? ''),
			],
		];

		if (isset($raw['sha'])) {
			$normalized['sha'] = $this->toString($raw['sha']);
		}

		return $normalized;
	}

	/**
	 * Convert mixed values to string in a predictable way.
	 *
	 * @param mixed $value
	 * @return string
	 */
	private function toString($value): string {
		if(is_string($value)) return $value;
		if(is_int($value) || is_float($value) || is_bool($value)) return (string) $value;
		if($value instanceof \Stringable) return (string) $value;
		return '';
	}

	/**
	 * Create a WireHttp instance pre-configured for GitHub API requests.
	 *
	 * Sets User-Agent and Accept headers required by the GitHub API.
	 * If $config->githubToken is set in /site/config.php it is sent as a
	 * Bearer token, raising the rate limit from 60 to 5 000 requests/hour.
	 *
	 * @return WireHttp
	 *
	 */
	protected function newGitHubHttp(): WireHttp {
		$http = new WireHttp();
		$this->wire($http);
		$http->setTimeout(self::TIMEOUT);
		$http->setHeader('User-Agent', 'ProcessWireUpgrade');
		$http->setHeader('Accept', 'application/vnd.github.v3+json');
		$token = $this->toString($this->wire()->config->githubToken ?? '');
		if($token) $http->setHeader('Authorization', "Bearer $token");
		return $http;
	}

	/**
	 * Extract GitHub owner and repository name from a URL
	 *
	 * @param string $url
	 * @return array{owner: string, repo: string}|null Array with owner/repo, or null if not a GitHub URL
	 *
	 */
	protected function extractGitHubOwnerRepo(string $url) {
		if(!preg_match('~github\.com/([^/#?]+)/([^/#?\s]+)~i', $url, $m)) return null;
		return ['owner' => $m[1], 'repo' => rtrim($m[2], '.')];
	}

	/**
	 * Fetch the latest commit SHA and date for a GitHub repository, cached for 6 hours
	 *
	 * @param string $owner GitHub owner or organisation
	 * @param string $repo GitHub repository name
	 * @param bool $refresh Force fetch, bypass cache
	 * @return array{sha: string, date: string}|false SHA and commit date, or false on failure
	 *
	 */
	protected function fetchModuleRemoteSha(string $owner, string $repo, bool $refresh = false): array|false {
		$cache = $this->cache;
		$cacheKey = "ProcessWireUpgrade_remoteSha_{$owner}_{$repo}";
		if(!$refresh) {
			$cached = $cache->get($cacheKey);
			if(is_array($cached) && isset($cached['sha']) && isset($cached['date'])) {
				return [
					'sha' => $this->toString($cached['sha']),
					'date' => $this->toString($cached['date']),
				];
			}
		}
		$url = "https://api.github.com/repos/{$owner}/{$repo}/commits?per_page=1";
		$http = $this->newGitHubHttp();
		$data = $http->getJSON($url);
		if(!is_array($data) || !isset($data[0]) || !is_array($data[0])) return false;
		$sha = $this->toString($data[0]['sha'] ?? '');
		if($sha === '') return false;
		$commit = $data[0]['commit'] ?? null;
		if(!is_array($commit)) return false;
		$committer = $commit['committer'] ?? null;
		if(!is_array($committer)) return false;
		$date = $this->toString($committer['date'] ?? '');
		$result = [
			'sha' => $sha,
			'date' => $date,
		];
		$cache->save($cacheKey, $result, 21600); // cache for 6 hours
		return $result;
	}

	/**
	 * Check all site modules for newer versions from the directory
	 *
	 * @param bool $onlyNew Only return array of modules with new versions available
	 * @param bool $refresh Force fresh data from remote services
	 * @param bool $checkSha Whether to check GitHub commit SHAs for unreleased changes (default=true)
	 * @return array<string, array{
	 *   title: string,
	 *   summary: string,
	 *   icon: string,
	 *   author: string,
	 *   href: string,
	 *   repo: string,
	 *   local: string,
	 *   remote: string|false,
	 *   new: int,
	 *   requiresVersions: array<string, array{0: string, 1: string}>,
	 *   installs: array<int, string>,
	 *   urls?: array<string, string>,
	 *   installer?: string,
	 *   pro?: bool,
	 *   sha?: string,
	 *   shaDate?: string
	 * }>
	 * @throws WireException
	 *
	 */
	public function getModuleVersions(bool $onlyNew = false, bool $refresh = false, bool $checkSha = true) {

		$modules = $this->modules;
		$config = $this->config;
		$cache = $this->cache;

		if(!$this->config->moduleServiceKey) {
			throw new WireException('Missing $config->moduleServiceKey in /site/config.php');
		}

		$url =
			$config->moduleServiceURL .
			"?apikey=" . $config->moduleServiceKey .
			"&version=2" .
			"&limit=100" .
			"&field=module_version,version,requires,urls" .
			"&class_name=";

		$names = [];
		$versions = [];

		foreach($modules as $module) {
			$name = $module->className();
			$info = $this->getModuleInfoVerbose($name);
			if($info['core']) continue;

			$names[] = $name;
			$versions[$name] = [
				'title'            => $info['title'],
				'summary'          => $info['summary'],
				'icon'             => $info['icon'],
				'author'           => $info['author'],
				'href'             => $info['href'],
				'repo'             => $info['repo'],
				'local'            => $info['versionStr'],
				'requiresVersions' => $info['requiresVersions'],
				'installs'         => $info['installs'],
				'remote'           => false,
				'new'              => 0,
			];
		}

		if(!$names) return [];

		$data = $refresh ? null : $this->session->getFor($this, 'moduleVersionsData');

		if(!is_array($data) || empty($data)) {
			// if not cached or refreshing
			$url .= implode(',', $names);
			$http = new WireHttp();
			$this->wire($http);
			$http->setTimeout(self::TIMEOUT);
			$data = $http->getJSON($url);
			$this->session->setFor($this, 'moduleVersionsData', $data);

			if(!is_array($data)) {
				$rawError = $http->getError();
				/** @var array<string>|string $rawError */
				$error = is_array($rawError) ? implode(', ', $rawError) : $rawError;
				if(!$error) $error = $this->_('Error retrieving modules directory data');
				$this->error($error . " (" . $this->className() . ")");
				return [];
			}
		}

		$newVersions = [];
		$installedBy = []; // moduleName => installedByModuleName
		if(!isset($data['items']) || !is_array($data['items'])) return $versions;
		$items = $data['items'];
		/** @var array<int, array<string, mixed>> $items */

		ksort($versions);

		foreach($items as $item) {
			if(!is_array($item)) continue;
			$name = $this->toString($item['class_name'] ?? '');
			if($name === '' || empty($versions[$name]) || empty($versions[$name]['local'])) continue;
			$localVersion = $this->toString($versions[$name]['local']);
			$remoteVersion = $this->toString($item['version'] ?? '');
			if($localVersion === '' || $remoteVersion === '') continue;
			$versions[$name]['remote'] = $remoteVersion;
			$new = version_compare($remoteVersion, $localVersion);

			$rawUrls = isset($item['urls']) && is_array($item['urls']) ? $item['urls'] : [];
			$urls = [];
			foreach($rawUrls as $urlKey => $urlValue) {
				$key = $this->toString($urlKey);
				if($key === '') continue;
				$urls[$key] = $this->toString($urlValue);
			}

			$versions[$name]['new'] = $new;
			$versions[$name]['urls'] = $urls;
			$versions[$name]['installer'] = '';
			$versions[$name]['pro'] = !empty($item['pro']);

			$directoryRepoUrl = $urls['repo'] ?? '';
			$localRepoUrl = $this->toString($versions[$name]['repo'] ?? '');
			$repoUrl = $this->useModuleInfoRepo ? $localRepoUrl : $directoryRepoUrl;
			$hrefRepoUrl = $this->toString($versions[$name]['href']);
			$hrefGh = $hrefRepoUrl !== '' ? $this->extractGitHubOwnerRepo($hrefRepoUrl) : false;
			if($repoUrl !== '') {
				$versions[$name]['urls']['repo'] = $repoUrl;
			}
			if($hrefGh && ($repoUrl === '' || $new < 0)) {
				$repoUrl = $hrefRepoUrl;
				$versions[$name]['urls']['repo'] = $hrefRepoUrl;
			}
			if($checkSha && $repoUrl !== '') {
				$gh = $this->extractGitHubOwnerRepo($repoUrl);
				if($gh) {
					$remoteShaData = $this->fetchModuleRemoteSha($gh['owner'], $gh['repo'], false);
					if($remoteShaData) $versions[$name]['shaDate'] = $remoteShaData['date'];
				}
			}

			$installs = $versions[$name]['installs'];
			if(!empty($installs)) {
				foreach($installs as $installsName) {
					$installedBy[$installsName] = $name;
				}
			}

			if($new <= 0) {
				// When versions match, optionally check for new commits on GitHub
				if($checkSha && $new === 0 && $repoUrl !== '') {
					$gh = $this->extractGitHubOwnerRepo($repoUrl);
					if($gh) {
						$remoteShaData = $this->fetchModuleRemoteSha($gh['owner'], $gh['repo'], false);
						if($remoteShaData) {
							$versions[$name]['shaDate'] = $remoteShaData['date'];
							// Key includes local version so the baseline resets automatically after a version upgrade
							$shaKey = "ProcessWireUpgrade_installedSha_{$name}_{$localVersion}";
							$installedSha = $cache->get($shaKey);
							if($installedSha === null) {
								// First check for this version — establish baseline silently
								$cache->save($shaKey, $remoteShaData['sha'], WireCache::expireNever);
							} elseif($installedSha !== $remoteShaData['sha']) {
								// New commits on GitHub since baseline was recorded
								$new = 1;
								$versions[$name]['new'] = 1;
								$versions[$name]['sha'] = $remoteShaData['sha'];
								$versions[$name]['shaDate'] = $remoteShaData['date'];
								$versions[$name]['remote'] = $this->toString($versions[$name]['remote']) . ' (' . substr($remoteShaData['sha'], 0, 7) . ')';
								// Baseline only advances after actual installation (version bumps →
								// new cache key → first-run baseline set silently). A bare Refresh
								// must NOT clear the notification, so we intentionally do nothing here.
							}
						}
					}
				}
	
				if($new <= 0) {
					// local is up-to-date or newer than remote
					if($onlyNew) unset($versions[$name]);
					continue;
				}
			}

			// remote is newer than local (by version or new GitHub commits)
			$requiresVersions = [];
			if(isset($item['requires']) && is_array($item['requires'])) {
				foreach($item['requires'] as $requiresName => $requiresPair) {
					if(!is_array($requiresPair)) continue;
					$reqName = $this->toString($requiresName);
					if($reqName === '') continue;
					$requiresVersions[$reqName] = [
						$this->toString($requiresPair[0] ?? ''),
						$this->toString($requiresPair[1] ?? ''),
					];
				}
			}
			$versions[$name]['requiresVersions'] = $requiresVersions;

			if(!$onlyNew) {
				$newVersions[$name] = $versions[$name];
				unset($versions[$name]);
			}
		}

		// SHA check for modules not listed in the PW directory but with a GitHub URL in their repo or href
		if($checkSha) {
			foreach($versions as $name => $item) {
				if($item['remote'] !== false) continue; // already handled via directory loop
				$repo = $this->toString($item['repo'] ?? '');
				$href = $this->toString($item['href'] ?? '');
				$gh = null;
				$repoIsGh = false;
				if($repo !== '') {
					$gh = $this->extractGitHubOwnerRepo($repo);
					$repoIsGh = (bool)$gh;
				}
				if(!$repoIsGh && $href !== '') {
					$gh = $this->extractGitHubOwnerRepo($href);
				}
				if(!$gh) continue;
				$remoteShaData = $this->fetchModuleRemoteSha($gh['owner'], $gh['repo'], false);
				if(!$remoteShaData) continue;
				$versions[$name]['shaDate'] = $remoteShaData['date'];
				$localVersion = $this->toString($item['local']);
				$shaKey = "ProcessWireUpgrade_installedSha_{$name}_{$localVersion}";
				$installedSha = $cache->get($shaKey);
				if($installedSha === null) {
					// First check — establish baseline silently
					$cache->save($shaKey, $remoteShaData['sha'], WireCache::expireNever);
				} elseif($installedSha !== $remoteShaData['sha']) {
					// New commits since baseline
					$versions[$name]['new'] = 1;
					$versions[$name]['sha'] = $remoteShaData['sha'];
					$versions[$name]['shaDate'] = $remoteShaData['date'];
					$versions[$name]['remote'] = $localVersion . ' (' . substr($remoteShaData['sha'], 0, 7) . ')';
					$versions[$name]['urls'] = ['repo' => $repoIsGh ? $repo : $href];
					$versions[$name]['installer'] = '';
					$versions[$name]['pro'] = false;
					if(!$onlyNew) {
						$newVersions[$name] = $versions[$name];
						unset($versions[$name]);
					}
				}
			}
		}

		if($onlyNew) {
			foreach($versions as $name => $item) {
				if($item['remote'] === false) unset($versions[$name]);
			}
		} elseif(count($newVersions)) {
			$versions = $newVersions + $versions;
		}

		foreach($versions as $name => $item) {
			if(!empty($versions[$name]['remote'])) continue;
			if(!isset($installedBy[$name])) continue;
			$installerName = $installedBy[$name];
			if(!isset($versions[$installerName])) continue;
			$versions[$name]['installer'] = $installerName;
			$installer = $versions[$installerName];
			if(!empty($installer['pro'])) $versions[$name]['pro'] = true;
		}

		return $versions;
	}

	/**
	 * Get all available branches with info for each
	 *
	 * @param bool $throw Whether or not to throw exceptions on error (default=true)
	 * @param bool $refresh Specify true to refresh data from web service
	 * @return array<string, array{
	 *   name: string,
	 *   title: string,
	 *   zipURL: string,
	 *   devzipURL: string,
	 *   version: string,
	 *   versionURL: string,
	 *   urls: array{repo: string, download: string, support: string},
	 *   sha?: string
	 * }>
	 * @throws WireException
	 *
	 */
	public function getCoreBranches(bool $throw = true, bool $refresh = false) {

		if(!$refresh) {
			$branches = $this->session->getFor($this, 'branches');
			if(is_array($branches) && count($branches)) {
				/** @var array<string, array{name: string, title: string, zipURL: string, devzipURL: string, version: string, versionURL: string, urls: array{repo: string, download: string, support: string}, sha?: string}> $branches */
				return $branches;
			}
		}

		$branches = [];
		$cache = $this->cache;

		// get sha and cache for 6 hours
		$sha = '';
		$shaDevCacheKey = 'ProcessWireUpgrade_devCoreSha';
		if(!$refresh) {
			$sha = $this->toString($cache->get($shaDevCacheKey));
		}
		if(empty($sha)) {
			$shaData = $this->newGitHubHttp()->getJSON('https://api.github.com/repos/processwire/processwire/commits?sha=dev&per_page=1');
			if(is_array($shaData) && isset($shaData[0]) && is_array($shaData[0]) && is_string($shaData[0]['sha'] ?? null)) {
				$sha = $shaData[0]['sha'];
				$cache->save($shaDevCacheKey, $sha, 21600); // 6 hours
			} else {
				$this->warning("ProcessWireUpgrade: unable to fetch latest dev commit SHA from GitHub — dev-latest branch will not be available.");
			}
		}

		foreach($this->repos as $repoName => $repo) {

			$http = $this->newGitHubHttp();
			$data = $http->getJSON($repo['branchesURL']);

			$loadError = $this->_('Error loading GitHub branches') . ' - ' . (string) $repo['branchesURL'];

			if(!is_array($data) || empty($data)) {
				$error = $loadError;
				$rawErr = $http->getError();
				/** @var array<string>|string $rawErr */
				$error .= ' - ' . $this->_('HTTP error(s):') . ' ' . (is_array($rawErr) ? implode(', ', $rawErr) : $rawErr);
				$error .= ' - ' . $this->_('Check that HTTP requests are not blocked by your server.');
				if($throw) throw new WireException($error);
				$this->error($error);
				return [];
			}

			foreach($data as $info) {

				if(!is_array($info) || empty($info['name']) || !is_string($info['name'])) continue;

				$name = $info['name'];

				$branch = [
					'name' => $name,
					'title' => ucfirst($name),
					'zipURL' => str_replace('{branch}', $name, $repo['zipURL']),
					'devzipURL' => str_replace('{sha}', $sha, $repo['devzipURL']),
					'version' => '',
					'versionURL' => str_replace('{branch}', $name, $repo['versionURL']),
				];

				$content = $http->get($branch['versionURL']);
				if(!is_string($content) || !preg_match_all('/const\s+version(Major|Minor|Revision)\s*=\s*(\d+)/', $content, $matches)) {
					$branch['version'] = '?';
					continue;
				}

				$version = [];
				foreach($matches[1] as $k => $var) {
					$version[$var] = (int) $matches[2][$k];
				}

				$branch['version'] = "$version[Major].$version[Minor].$version[Revision]";

				$url = 'https://github.com/processwire/processwire';
				$branch['urls'] = [
					'repo' => ($name === 'dev' ? "$url/tree/dev" : $url),
					'download' => "$url/archive/refs/heads/$name.zip",
					'support' => 'https://processwire.com/talk/',
				];

				if($repoName != 'main') {
					$name = "$repoName-$name";
					$branch['name'] = $name;
					$branch['title'] = ucfirst($repoName) . "/$branch[title]";
				}

				$branches[$name] = $this->normalizeBranch($branch);
			}
		}

		// Add a bleeding-edge dev-latest entry based on the latest commit SHA
		if(!empty($sha) && isset($branches['dev'])) {
			$devLatest = $branches['dev'];
			$devLatest['name'] = 'dev-latest';
			$devLatest['title'] = 'Dev (latest commit)';
			$devLatest['zipURL'] = $devLatest['devzipURL']; // SHA-based archive URL
			$devLatest['sha'] = $sha;
			$branches['dev-latest'] = $this->normalizeBranch($devLatest);
		}

		$this->session->setFor($this, 'branches', $branches);

		return $branches;
	}

}
