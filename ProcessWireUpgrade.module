<?php namespace ProcessWire;

require_once __DIR__ . '/ProcessWireUpgradeUtilsTrait.php';
require_once __DIR__ . '/ProcessWireUpgradeLogsTrait.php';
require_once __DIR__ . '/ProcessWireUpgradeCacheTrait.php';
require_once __DIR__ . '/ProcessWireUpgradeWireHttpMulti.php';

/**
 * Tool to display available core and module upgrades for ProcessWire
 *
 * ProcessWire
 * Copyright (C) 2023 by Ryan Cramer
 * Licensed under MPL 2.0
 *
 * https://processwire.com
 *
 * @phpstan-import-type CoreBranch from ProcessWireUpgradeCheck
 */

class ProcessWireUpgrade extends Process {

	use ProcessWireUpgradeUtilsTrait;
	use ProcessWireUpgradeLogsTrait;
	use ProcessWireUpgradeCacheTrait;

	/**
	 * Return information about this module
	 *
	 * @return array<string, mixed>
	 */
	public static function getModuleInfo(): array {
		return [
			'title' => 'Upgrades',
			'summary' => 'Tool that helps you identify and install core and module upgrades.',
			'version' => 15,
			'author' => 'Ryan Cramer, Matjaž Potočnik, AI',
			'href' => 'https://github.com/matjazpotocnik/ProcessWireUpgrade',
			//'href' => 'https://processwire.com/talk/topic/7525-module-processwire-core-upgrade/',
			'installs' => 'ProcessWireUpgradeCheck',
			'requires' => ['ProcessWire>=3.0.246', 'PHP>=8.2'],
			'icon' => 'coffee',
		];
	}

	const PAGE_NAME = 'upgrades';

	/** Hours after last refresh before forcing a new one */
	const REFRESH_THRESHOLD_HOURS = 24;

	/**
	 * Path to /wire/
	 */
	protected string $wirePath = '';

	/**
	 * Temporary path used by installer for download and ZIP extraction
	 */
	protected string $tempPath = '';

	/**
	 * Temporary path used by installer for file storage when file system isn't writable
	 */
	protected string $cachePath = '';

	/**
	 * Array of renames (oldPath => newPath) scheduled for renames to occur
	 * after page render in __destruct
	 *
	 * @var array<string, string>
	 */
	protected array $renames = [];

	/**
	 * Instance of ProcessWireUpgradeCheck
	 *
	 * @var ProcessWireUpgradeCheck
	 */
	protected $checker;


	/**
	 * API wired
	 */
	public function wired(): void {
		parent::wired();
		$this->initPaths();
	}

	/**
	 * Initialize and perform access checks
	 *
	 * @throws WireException|WirePermissionException
	 */
	public function init(): void {
		if($this->config->demo) {
			throw new WireException($this->_('This module cannot be used in demo mode.'));
		}
		if(!$this->user->isSuperuser()) {
			throw new WirePermissionException($this->_('This module requires superuser privileges.'));
		}
		$checker = $this->modules->getInstall('ProcessWireUpgradeCheck');
		if(!$checker) {
			throw new WireException(
				$this->_("Please go to Modules and click 'Check for new modules' - this will auto-update ProcessWireUpgrade.")
			);
		}

		/** @var ProcessWireUpgradeCheck $checker */
		$this->checker = $checker;

		parent::init();
	}

	/**
	 * Initialize paths used by this module
	 */
	protected function initPaths(): void {
		$config = $this->config;
		$this->wirePath = $config->paths->root . 'wire/';
		$this->tempPath = $config->paths->cache . $this->className() . '/';
		$this->cachePath = $config->paths->cache . 'core-upgrade/';
	}

	/**
	 * Get info for either a specific core branch, or for the currently selected core branch
	 *
	 * @param string $name Core branch name (e.g. 'master', 'dev'), or empty for the session-stored branch
	 * @return CoreBranch|array{}
	 */
	protected function getBranch(string $name = ''): array {
		$branches = $this->checker->getCoreBranches();
		if(empty($name)) $name = $this->toString($this->session->getFor($this, 'branch'));
		$branch = $branches[$name] ?? [];
		return is_array($branch) ? $branch : [];
	}

	/**
	 * Set the current core branch in session
	 *
	 * @param string $name Core branch name to persist for this user
	 */
	protected function setBranch(string $name): void {
		$this->session->setFor($this, 'branch', $name);
	}

	/**
	 * Performs basic checks (requirements, pending files, refresh status) before listing modules
	 */
	protected function preflight(): string {

		if(!class_exists('\ZipArchive')) {
			$this->warning(
				"Your PHP does not have ZipArchive support. This is required to install core or module upgrades with this tool. " .
				"You can still use this tool to identify new versions and install them manually."
			);
		}

		// Skip non-existent paths
		$upgradePaths = [$this->cachePath, $this->tempPath];
		$upgradePaths = array_filter($upgradePaths, 'file_exists');

		if(!empty($upgradePaths)) {
			/** @var InputfieldButton $btn */
			$btn = $this->modules->get('InputfieldButton');
			$btn->href = "./remove";
			$btn->value = $this->_('Remove');
			$btn->icon = 'trash-o';
			return
				$this->h('Upgrade files are already present. Please remove them before continuing.') .
				$this->ul($upgradePaths) .
				$this->p($btn->render());
		}

		$lastRefresh = $this->session->getFor($this, 'lastModulesRefreshTime');

		if(!$lastRefresh || $lastRefresh < (time() - self::REFRESH_THRESHOLD_HOURS * 3600)) {
			$btn = $this->refreshButton();
			$btn->value = $this->_('Continue');
			$btn->icon = 'angle-right';
			return
				$this->h('The latest core and module versions will be loaded from the ProcessWire modules directory.') .
				$this->p('Please be patient, this may take a few seconds to complete.') .
				$this->p($btn->render()) .
				$this->lastRefreshInfo();
		}

		return '';
	}

	/**
	 * Build and render a modules version/update table for the admin UI.
	 *
	 * - Retrieves core and module version data
	 * - Determines update/download/sync actions and labels
	 * - Generates links (support, repo, directory)
	 * - Renders child modules where applicable
	 *
	 * @return string Rendered HTML output
	 */
	public function execute(): string {
		$timer = Debug::startTimer();
		$this->debug('Execute started.');
		$sanitizer = $this->sanitizer;
		$modules = $this->modules;
		$config = $this->config;

		$preflight = $this->preflight();
		if($preflight) return $preflight;

		// Whether to include GitHub commit SHA checks for this request.
		// Set by the user clicking "Check GitHub for updates" button.
		$checkGitHubSha = (bool) $this->session->getFor($this, 'githubTrackingEnabled');

		// Fetch all core branch and module version data, with optional SHA checks
		$items = $this->checker->getVersions(false, $checkGitHubSha);

		// Re-check after getVersions() in case this run just established baselines
		$hasGitHubBaseline = $this->checker->hasGitHubBaseline();

		/** @var MarkupAdminDataTable $table */
		$table = $modules->get('MarkupAdminDataTable');
		$table->setEncodeEntities(false);

		// Build table headers — "Last Commit" only shown when SHA baselines exist
		$headers = [
			$this->_('Title'),
			$this->_('Name'),
			$this->_('Installed'),
			$this->_('Latest'),
		];
		if($hasGitHubBaseline) {
			$headers[] = $this->_('Last Commit');
		}
		$headers[] = $this->_('Status');
		$headers[] = $this->_('Links');
		$table->headerRow($headers);
		//$table->setColNotSortable(count($headers)-1); //links not sortable

		// for debugging purposes
		$labelCounts = ['Upgrade' => 0, 'Sync' => 0, 'Download' => 0, 'Unavailable' => 0, 'Up-to-date' => 0, 'Up-to-date+' => 0, 'Managed by' => 0, 'LocalOnly' => 0];

		// 1. Iterate items — each core branch or module becomes one table row
		foreach($items as $name => $item) {

			// Normalize item fields — type-cast, sanitize, set defaults
			$local = (string) $item['local'];
			$remote = (string) $item['remote'];
			if(empty($local)) continue;

			// Strip any SHA suffix (e.g. " (abc1234)") before version comparison;
			$cleanRemote = (string) preg_replace('/\s*\([0-9a-f]{7,}\)\s*$/', '', $remote);
			$isVersionUpgrade = version_compare($cleanRemote, $local) > 0;
			$remote = $sanitizer->entities1($remote);
			$local = $sanitizer->entities1($local);

			$branch = $item['branch'] ?? '';
			$new = (int) ($item['new'] ?? 0);
			$installed = (bool) ($item['installed'] ?? false);
			$class = !$installed ? 'not_installed' : '';
			$urls = $item['urls'] ?? [];
			$links = [];
			$upgradeLabel = $this->_('Up-to-date');
			$upgradeURL = '';

			// Check if any child module needs an update — promote parent to trigger Upgrade/Sync
			if(!empty($item['childModules']) && is_array($item['childModules'])) {
				foreach($item['childModules'] as $childData) {
					if(intval($this->toString($childData['new'] ?? '')) > 0) {
						$new = 1;
						break;
					}
				}
			}

			// 2. Determine default label — "Up-to-date" or local-ahead ("+")
			if(empty($remote)) {
				$upgradeLabel = '';
			} elseif($new < 0) {
				$upgradeLabel .= '+';
			} // 2.

			// 3. Newer version available — assign action label and URL by item type
			if($new > 0 && !empty($remote)) {
				$remote = $this->b($remote);

				// 3a. Core branch -> Upgrade
				if(!empty($branch)) {
					$upgradeURL = './check?branch=' . urlencode($branch);
					$upgradeLabel = $this->_('Upgrade');
					$labelCounts['Upgrade']++;
				} // 3a.

				// 3b. Uninstalled module -> Download or Unavailable
				elseif(!$installed) {
					if(!empty($item['urls']['repo'])) {
						$upgradeURL = './module-download?name=' . urlencode($name) . '&repo=' . urlencode($item['urls']['repo']);
						if(!empty($item['sha'])) $upgradeURL .= '&sha=' . urlencode($item['sha']);
						$upgradeLabel = $this->_('Download');
						$labelCounts['Download']++;
					} else {
					// Failsafe: Cannot download uninstalled module without a repo URL
					$upgradeLabel = $this->_('Unavailable');
					$labelCounts['Unavailable']++;
					}
				} // 3b.

				// 3c. Installed module -> Sync or Upgrade
				else {
					// Version matches but unreleased commits on GitHub -> Sync.
					// Promoted parents (those shown as needing update only because
					// a child module needs one) are included: Sync from the shared
					// repo brings in the child's updates without the parent having
					// a version bump of its own.
					if(!$isVersionUpgrade && !empty($item['sha']) && !empty($item['urls']['repo'])) {
						$upgradeURL = './module-download?name=' . urlencode($name) .
													'&repo=' . urlencode($item['urls']['repo']) .
													'&sha=' . urlencode($item['sha']);
						$upgradeLabel = $this->_('Sync');
						$labelCounts['Sync']++;
					}

					// Clean version bump or standard fallback -> Upgrade
					else {
						$upgradeURL = $config->urls->admin . 'module/?update=' . urlencode($name);
						$upgradeLabel = $this->_('Upgrade');
						$labelCounts['Upgrade']++;
					}
				} // 3c.

			} // 3.

			// 4. Local-only module — no remote directory entry (shown only in debug mode)
			elseif(!empty($item['localOnly'])) {
				$upgradeLabel = $this->_('Not in directory');
				$class .= ' local-only';
				$labelCounts['LocalOnly']++;
			} // 4.

			// 5. Up-to-date or local-ahead — no action required
			elseif(!empty($remote)) {
				$labelCounts[$new < 0 ? 'Up-to-date+' : 'Up-to-date']++;
			} // 5.

			// 6. Render action label — clickable link if actionable, plain span otherwise
			if($new > 0 && !empty($upgradeURL)) {
				$upgrade = $this->a($upgradeURL, $upgradeLabel);
			} else {
				$upgrade = $this->span($upgradeLabel, 'detail');
			} // 6.

			// 7. Build link icons — support, repository/repo, directory
			foreach($urls as $key => $url) {
				$urls[$key] = $sanitizer->entities($url);
			}
			$href = $this->toString($item['href'] ?? '');
			if(!empty($urls['support'])) {
				$links[] = $this->iconLink('life-ring', $urls['support'], 'Support');
			}
			if(!empty($urls['repo']) && str_contains($urls['repo'], 'github.com')) {
				$links[] = $this->iconLink('github-alt', $urls['repo'], 'GitHub');
			} elseif(!empty($urls['repo'])) {
				$links[] = $this->iconLink('info-circle', $urls['repo'], 'Details');
			} elseif($href !== '' && str_contains($href, 'github.com')) {
				$links[] = $this->iconLink('github-alt', $href, 'GitHub');
			} elseif($href !== '') {
				$links[] = $this->iconLink('info-circle', $href, 'Info');
			}
			if(!empty($urls['dir'])) {
				$links[] = $this->iconLink('share-alt', $urls['dir'], 'Directory');
			}

			// 8. Drop row — skip items with neither remote version nor any links.
			// Note: this also skips child "Managed by" rows (rendered below), so if a
			// parent has no remote data of its own AND no links, its children vanish too.
			if(empty($remote) && empty($links)) continue;

			// 9. Render title — icon + module name + optional PRO badge + config link
			$icon = empty($item['icon']) ? wireIconMarkup('plug', 'fw') : wireIconMarkup($sanitizer->entities($item['icon']), 'fw');
			$title = $icon . ' ' . $sanitizer->entities1($item['title']);
			$proLabel = ' ' . $this->span('PRO', 'pro');
			if(!empty($item['pro'])) {
				$title = $this->a($upgradeURL, $title, $class) . $proLabel;
				if($item['new'] > 0) {
					$proSupportURL = !empty($urls['support']) ? $urls['support'] : $upgradeURL;
					$protip = 'PRO module upgrade available in ProcessWire VIP support board (login required)';
					$upgrade = $this->tooltip($protip, $this->aa($proSupportURL, $upgradeLabel));
				}
			} else {
				if (!empty($item['branch'])) {
					$configURL = !empty($urls['repo'])
						? $urls['repo']
						: ProcessWireUpgradeCheck::GH_GIT_BASE . ProcessWireUpgradeCheck::REPO . '/tree/' . urlencode((string)$item['branch']);
				} elseif ($installed) {
					$configURL = $config->urls->admin . 'module/edit?name=' . urlencode($name);
				} else {
					$t = rawurlencode($sanitizer->unentities($item['title']));
					$configURL = $config->urls->admin . 'module/#tab_install_modules:~:text=' . $t;
				}
				$title = $this->a($configURL, $title, $class);
			} // 9.

			// 10. Render commit date — last GitHub activity (only visible when tracking is active)
			$shaDate = '';
			if (isset($item['shaDate']) && is_string($item['shaDate']) && $item['shaDate'] !== '') {
				$timestamp = strtotime($item['shaDate']);
				if ($timestamp !== false) {
					//$sha = substr($item['sha'], 0, 7);
					$shaDate = "<span class='sr-only'>$timestamp </span>" . wireRelativeTimeStr($timestamp);
				}
			} // 10.

			// 11. Assemble row and append to table
			$row = [
				$title,
				$name,
				$local,
				$remote,
			];
			if($hasGitHubBaseline) {
				$row[] = $shaDate;
			}
			$row[] = $upgrade;
			$row[] = $this->span(implode(' ', $links), 'links');
			$table->row($row);

			// 12. Render child modules — "Managed by" rows for sub-modules of this parent
			if(!empty($item['childModules']) && is_array($item['childModules'])) {
				foreach($item['childModules'] as $childName => $childData) {
					if(!$modules->isInstalled($childName)) continue;
					$childLocal = $this->toString($childData['local'] ?? '');
					$childRemote = $this->toString($childData['remote'] ?? '');
					$childTitleText = $this->toString($childData['title'] ?? $childName);
					$childTitle = "<span class='sr-only'>$title </span>" .
												"<span class='detail is_child'>" . " " .
												$icon .
												$sanitizer->entities1($childTitleText) . "</span>";
					$childName = "<span class='sr-only'>$name </span>" .
											 $sanitizer->entities1($childName);
					$row = [
						$childTitle,
						$this->span($childName, 'detail'),
						$this->span($sanitizer->entities1($childLocal), 'detail'),
						$this->span($sanitizer->entities1($childRemote), 'detail'),
					];
					if($hasGitHubBaseline) {
						$row[] = ''; // don't show SHA date to keep it clean
					}
					$row[] = $this->span($this->_('Managed by') . ' ' . $sanitizer->entities1($name), 'detail');
					$row[] = ''; // don't show action links to keep it clean
					$table->row($row);
					$labelCounts['Managed by']++;
				}
			} // 12.
		} // foreach

		// Help text above buttons
		$helpTextMessage = $hasGitHubBaseline
			? $this->_('Refresh the core and module list, then check GitHub for new commits and releases.')
			: $this->_('Refresh the core and module list, then initialize GitHub tracking to monitor for unreleased updates.');
		$helpText = $this->p($helpTextMessage, 'help-text');

		$githubBtnLabel = $hasGitHubBaseline
			? $this->_('Check GitHub for Updates')
			: $this->_('Initialize GitHub Tracking');

		// Surface any GitHub API degradation from this request
		$ghWarning = $this->checker->getGitHubRefreshWarning();
		if($ghWarning !== '') {
			$this->warning($ghWarning, true);
		}

		$elapsed = Debug::stopTimer($timer);
		$this->log(
			'Execute finished; items=' . count($items) .
			'; Upgrade=' . $labelCounts['Upgrade'] .
			'; Sync=' . $labelCounts['Sync'] .
			'; Download=' . $labelCounts['Download'] .
			'; Unavailable=' . $labelCounts['Unavailable'] .
			'; Up-to-date=' . $labelCounts['Up-to-date'] .
			'; Up-to-date+=' . $labelCounts['Up-to-date+'] .
			'; Managed by parent=' . $labelCounts['Managed by'] .
			'; LocalOnly=' . $labelCounts['LocalOnly'] .
			'; elapsed=' . $elapsed
		);

		$summary = $this->renderStatsLine($labelCounts);

		return
			$helpText .
			$summary .
			$this->lastRefreshInfo() .
			$table->render() .
			$this->p($this->refreshButton(true)->render() . ' ' . $this->githubCheckButton(true, $githubBtnLabel)->render());
	}

	/**
	 * Refresh module versions data
	 */
	public function executeRefresh(): void {
		$this->debug('Refresh Core & Modules List started.');
		$timer = Debug::startTimer();
		$this->session->setFor($this, 'lastModulesRefreshTime', time());

		// Full refresh: re-scan local modules for newly installed/removed modules
		$this->modules->refresh();

		// For a clean fallback state, flush remote SHA cache
		$this->checker->clearTemporaryRemoteShaCache();

		// Fetch fresh core branches + module versions
		$checkSha = (bool) $this->session->getFor($this, 'githubTrackingEnabled');
		$this->checker->getVersions(true, $checkSha);

		// Clear loginHook so the next login re-fetches fresh upgrade data
		$this->cache->delete($this->cacheKey('loginHook'));

		// Retrieve and display any GitHub API warning
		$warning = $this->checker->getGitHubRefreshWarning();
		if($warning !== '') {
			$this->warning($warning, true);
		}

		$this->message($this->_('Refreshed core and modules list.'), true);
		$elapsed = Debug::stopTimer($timer);
		$this->log('Refresh Core & Modules List finished; elapsed=' . $elapsed);
		$this->session->location('./');
	}

	/**
	 * Check GitHub latest commits for installed and optionally uninstalled modules.
	 */
	public function executeGithubRefresh(): void {
		$this->debug('Check GitHub for updates started.');
		$timer = Debug::startTimer();
		$this->session->setFor($this, 'lastGithubRefreshTime', time());
		$this->session->setFor($this, 'githubTrackingEnabled', true);

		// Flush the remote SHA cache so module SHAs are re-fetched.
		// (getVersions($refresh=true) already bypasses the branches cache
		// internally, so no explicit branches delete is needed.)
		$this->checker->clearTemporaryRemoteShaCache();
		$this->checker->getVersions(false, true);

		// Clear loginHook so the next login re-fetches fresh upgrade data
		$this->cache->delete($this->cacheKey('loginHook'));

		// Retrieve and display any GitHub API warning
		$warning = $this->checker->getGitHubRefreshWarning();
		if($warning !== '') {
			$this->warning($warning, true);
		}

		$this->message($this->_('Checked GitHub for updates.'), true);
		$elapsed = Debug::stopTimer($timer);
		$this->log('Check GitHub for updates finished; elapsed=' . $elapsed);
		$this->session->location('./');
	}

	/**
	 * Download and install a module from GitHub (SHA-based update, no version bump)
	 */
	public function executeModuleDownload(): void {
		$input = $this->input;
		$sanitizer = $this->sanitizer;
		$modules = $this->modules;

		$name = $sanitizer->name($this->toString($input->get('name')));
		$repo = $sanitizer->url($this->toString($input->get('repo')));
		$sha  = $sanitizer->text($this->toString($input->get('sha')));

		$this->debug("Module download started; name=$name; repo=$repo; sha=" . ($sha ? substr($sha, 0, 7) : '(none)'));

		if(!$name) $this->abort($this->_('Missing module name for download.'));
		if(!$repo) $this->abort($this->_('Missing repository URL for module download.'));
		if(!preg_match('~^https://github\.com/~i', $repo)) $this->abort($this->_('Only GitHub repositories are supported.'));
		if($sha !== '' && !preg_match('/^[0-9a-f]{40}$/i', $sha)) $this->abort($this->_('Invalid commit hash.'));

		// Use SHA-pinned archive when available to avoid race conditions with new commits.
		// Fall back to HEAD only when no SHA was provided (e.g. uninstalled module download).
		$zipUrl = $sha
			? rtrim($repo, '/') . '/archive/' . $sha . '.zip'
			: rtrim($repo, '/') . '/archive/HEAD.zip';

		$this->debug("Module download ZIP URL; name=$name; url=$zipUrl");

		// Symlink preservation
		$preserveSymlinks = (bool) $this->config->get('processWireUpgradePreserveSymlinks');
		$realModulePath = $preserveSymlinks ? $this->getSymlinkedModulePath($name) : false;
		$downloadDestinationDir = '';

		if($realModulePath !== false) {
			// Module is symlinked and config allows preservation.
			// Delegate to core downloader but target the resolved real directory directly,
			// so backup/restore runs on the real path and the symlink path remains untouched.
			$this->debug("Module is symlinked, preserving link; realpath=$realModulePath");
			$downloadDestinationDir = $realModulePath;
		}

		/** @var ProcessModule $processModule */
		$processModule = $modules->get('ProcessModule');
		$destinationDir = $processModule->installer()->downloadModule($zipUrl, $downloadDestinationDir);

		if($destinationDir) {
			$msg = $realModulePath !== false
				? sprintf($this->_('Module %s updated from GitHub (symlink preserved).'), $name)
				: sprintf($this->_('Module %s updated from GitHub.'), $name);
			$this->message($msg, true);
			$this->checker->clearVersionsCache();

			if($sha !== '') {
				if($modules->isInstalled($name)) {
					// Advance the installed SHA baseline so the notification clears
					$localVer = $modules->formatVersion($modules->getModuleInfoVerbose($name)['version'] ?? 0);
					$shaKey = $this->cacheKey('installedSha', $name, $localVer);
					$this->cache->save($shaKey, $sha, $this->cacheTtl('installedSha'));
					
					// Clear the last-good SHA cache — it will be refreshed on next check
					$this->checker->deleteLastGoodRemoteSha($repo);
				} else {
					// Module was just downloaded but not yet installed —
					// refresh disk info and clear session so next check starts fresh
					$this->refreshSingleModule($name);
				}
			}
		} else {
			$this->error(sprintf($this->_('Failed to download module %s from GitHub'), $name), true);
		}

		$this->log('Module download finished; name=' . $name . '; symlinked=' . ($realModulePath !== false ? 'yes' : 'no') . '; success=' . ($destinationDir ? 'yes' : 'no'));
		$this->session->location('./');
	}

	/**
	 * Remove existing installation files
	 */
	public function executeRemove(): void {
		$paths = array_filter([$this->cachePath, $this->tempPath], 'file_exists');

		foreach($paths as $path) {
			if(wireRmdir($path, true)) {
				$this->message(sprintf($this->_('Removed: %s'), $path));
			} else {
				$this->error(sprintf($this->_('Failed to remove path (please remove manually): %s'), $path), true);
			}
		}

		// Preserve GitHub tracking state — user didn't ask to reset it
		$trackingEnabled = $this->session->getFor($this, 'githubTrackingEnabled');
		$this->session->removeAllFor($this);
		if($trackingEnabled) $this->session->setFor($this, 'githubTrackingEnabled', true);

		$this->session->location('./');
	}

	/**
	 * Check the selected branch and compare to current version to see if user wants to continue
	 *
	 * @return string Rendered HTML output
	 */
	public function executeCheck(): string {
		$version = $this->config->version;

		$this->coreUpgrade();

		if(!$this->config->debug) {
			$this->warning(
				$this->_("While optional, we recommend that you enable debug mode during the upgrade so that you will see detailed error messages, should they occur. ") .
				$this->_("Do this by editing /site/config.php and setting the debug option to true. Example: \$config->debug = true;")
			);
		}

		$name = $this->sanitizer->name($this->toString($this->input->get('branch')));
		if($name === '') $this->abort($this->_('No branch selected.'));

		$branch = $this->getBranch($name);
		if(!count($branch)) $this->abort(sprintf($this->_('Unknown branch %s.'), $name));

		$branchName = $branch['name'];
		$branchVersion = $branch['version'];
		if($branchVersion === '') $this->abort($this->_('Unknown branch version.'));

		$this->headline(sprintf($this->_('ProcessWire Core (%s)'), $name));
		$this->setBranch($name);

		$result = version_compare($branchVersion, $version);

		$msg = match(true) {
			$result > 0 => sprintf($this->_('The available version (%s) is newer than the one you currently have (%s).'), $branchVersion, $version),
			$result < 0 => sprintf($this->_('The available version (%s) is older than the one you currently have (%s).'), $branchVersion, $version),
			default     => $this->_('The available version is the same as the one you currently have.'),
		};

		$this->debug("Core branch version compared; branch=$name; local=$version; remote=$branchVersion; result=$result");
		
		$out = $this->p(sprintf($this->_('Do you want to download and install ProcessWire %s version %s?'), $branchName, $branchVersion)) . $this->p($msg);

		/** @var InputfieldButton $btn */
		$btn = $this->modules->get('InputfieldButton');
		$btn->href = "./download";
		$btn->value = $this->_('Download Now');
		$btn->icon = 'cloud-download';
		$out .= $btn->render();

		/** @var InputfieldButton $btn */
		$btn = $this->modules->get('InputfieldButton');
		$btn->href = "./";
		$btn->value = $this->_('Abort');
		$btn->icon = 'times-circle';
		$btn->addClass('ui-priority-secondary');
		$out .= $btn->render();

		$out .= $this->p($this->_('After clicking the download button, be patient, as this may take a minute.'), 'detail');

		return $out;
	}

	/**
	 * Download the selected branch ZIP file
	 */
	public function executeDownload(): void {
		$branch = $this->getBranch();
		if(empty($branch)) $this->abort($this->_('No branch selected.'));

		$branchName = $branch['name'];
		$branchVersion = $branch['version'];
		$branchZipURL = $branch['zipURL'];

		if($branchName === '' || $branchVersion === '' || $branchZipURL === '') $this->abort($this->_('No branch selected.'));

		$this->debug("Core download started; branch=$branchName; version=$branchVersion");

		wireMkdir($this->tempPath);
		$http = new WireHttp();
		$this->wire($http);
		$zipfile = $http->download($branchZipURL, $this->tempPath . "$branchName.zip");

		if(!$zipfile || !file_exists($zipfile) || !filesize($zipfile)) {
			$this->abort(sprintf($this->_('Unable to download ProcessWire from %s.'), $branchZipURL));
		}

		// Validate ZIP integrity early if ZipArchive is available,
		// before the user proceeds through the database step.
		if(class_exists('\ZipArchive')) {
			$za = new \ZipArchive();
			$zipOk = $za->open($zipfile) === true;
			$za->close();
			if(!$zipOk) {
				$this->abort($this->_('Downloaded ZIP file appears to be corrupt. Please try again.'));
			}
		}

		$bytes = number_format((int) filesize($zipfile));
		$this->log("Core download finished; branch=$branchName; version=$branchVersion; bytes=$bytes");
		$this->message(sprintf(
			$this->_('Downloaded version %s (%s bytes)'),
			$branchVersion,
			$bytes
		));

		$this->session->location('./database');
	}

	/**
	 * Export database or instruct them to do it
	 *
	 * @return string Rendered HTML output
	 */
	public function executeDatabase(): string {
		$this->coreUpgrade();

		$config = $this->config;
		$session = $this->session;
		$modules = $this->modules;

		$session->removeFor($this, 'database');

		$branch = $this->getBranch();
		if(empty($branch)) $this->abort($this->_('No branch selected.'));

		$branchVersion = $branch['version'];
		$canBackup = class_exists('\\ProcessWire\\WireDatabaseBackup');

		if($this->input->get('backup') && $canBackup) {
			$options = [
				'filename' => $config->dbName . "-" . $config->version . "-" . date('Y-m-d_H-i-s') . ".sql",
				'description' => "Automatic backup made by ProcessWireUpgrade before upgrading from {$config->version} to $branchVersion."
			];
			$backups = $this->database->backups();
			$file = $backups->backup($options);
			$errors = $backups->errors();
			if(!empty($errors)) {
				$cleanErrors = [];
				foreach($errors as $error) {
					$errString = $this->toString($error);
					$cleanErrors[] = $errString;
					$this->error($errString); // UI-Only alerts to prevent log bloating
				}
				$this->log("Database backup engine returned warnings/errors during dump. ", ['engine_errors' => $cleanErrors]);
			}
			if($file) {
				clearstatcache();
				$bytes = filesize($file);
				$file = str_replace($config->paths->root, '/', $file);
				$this->message("Backup saved to $file ($bytes bytes) - Please note this location should you later need to restore it.", true);
				$session->setFor($this, 'database', $file);
			} else {
				$this->error($this->_('Database backup failed.'), true);
			}
			$session->location('./prepare');
		}

		$out = $this->h($this->_('Database Backup'));

		if($canBackup) {
			$out .= $this->p($this->_('Your version of ProcessWire supports automatic database backups.*'));

			/** @var InputfieldButton $btn */
			$btn = $modules->get('InputfieldButton');
			$btn->href = "./database?backup=1";
			$btn->value = $this->_('Backup Database Now');
			$btn->icon = 'database';
			$out .= $btn->render();

			/** @var InputfieldButton $btn */
			$btn = $modules->get('InputfieldButton');
			$btn->href = "./prepare";
			$btn->icon = 'angle-right';
			$btn->value = $this->_('Skip Database Backup');
			$btn->addClass('ui-priority-secondary');
			$out .= $btn->render();

			$out .= $this->p($this->_('*It is also recommended to create an independent database backup, for example using phpMyAdmin.'), 'detail');

		} else {
			$out .= $this->p(
				$this->_('Your current version of ProcessWire does not support automatic database backups.') . ' ' .
				sprintf($this->_('It is recommended to create a backup of the database %s, for example using phpMyAdmin.'), $config->dbName) . ' ' .
				$this->_('Click the button below once you have saved a backup.')
			);

			/** @var InputfieldButton $btn */
			$btn = $modules->get('InputfieldButton');
			$btn->href = "./prepare";
			$btn->icon = 'angle-right';
			$btn->value = $this->_('Confirm');
			$out .= $btn->render();
		}

		return $this->out($out);
	}

 	/** Unzips the selected upgrade package, prepares files for installation,
	 * and outputs instructions or options for installing the upgrade.
	 *
	 * @return string Rendered HTML
	 */
	public function executePrepare(): string {
		$config = $this->config;

		$this->coreUpgrade();

		$branch = $this->getBranch();
		if(empty($branch)) $this->abort($this->_('No branch selected.'));

		$branchName = $branch['name'];
		$branchVersion = $branch['version'];
		if($branchName === '' || $branchVersion === '') $this->abort($this->_('No branch selected.'));

		$zipfile = $this->tempPath . "$branchName.zip"; // site/assets/cache/ProcessWireUpgrade/branch-dev.zip

		if(!file_exists($zipfile)) $this->abort(sprintf($this->_('Unable to locate ZIP: %s.'), $zipfile));
		$this->debug("Unzipping core framework archive; zipfile=$zipfile");
		$files = wireUnzipFile($zipfile, $this->tempPath);
		if(!count($files)) $this->abort(sprintf($this->_('No files were found in %s.'), $zipfile));

		$oldVersion = $config->version;
		$newVersion = $branchVersion;

		$rootPath = dirname(rtrim($this->wirePath, '/')) . '/';
		$rootTempPath = $this->tempPath;  // site/assets/cache/ProcessWireUpgrade/
		$wireTempPath = $this->tempPath . 'wire/'; // site/assets/cache/ProcessWireUpgrade/wire/
		$wireNewName = "wire-$newVersion"; // wire-2.5.0

		if(!is_dir($wireTempPath)) {
			// adjust paths according to where they were unzipped, as needed
			// need to drill down a level from extracted archive
			// i.e. files[0] may be a dir like /ProcessWire-dev/
			$rootTempPath = $this->tempPath . trim($this->toString($files[0] ?? ''), '/') . '/';
			$wireTempPath = $rootTempPath . "wire/";
			if(!is_dir($wireTempPath)) $this->abort(
				text: $this->_('Unable to find /wire/ directory in archive.'),
				context: ['extracted_files_sample' => array_slice($files, 0, 10)]);
		}

		$indexNewName = "index-$newVersion.php"; // index-2.5.0.php
		$htaccessNewName = "htaccess-$newVersion.txt"; // htaccess-2.5.0.txt

		// --- index.php Version Check ---
		// NEW index comes from the freshly extracted zip ($rootTempPath)
		$newIndexPath = $rootTempPath . 'index.php';
		if(!file_exists($newIndexPath)) {
			$this->abort(sprintf($this->_('Required file %s not found in archive.'), 'index.php'));
		}
		$newIndexData    = (string) file_get_contents($newIndexPath);
		$newIndexVersion = preg_match('/define\("PROCESSWIRE", (\d+)\);/', $newIndexData, $matches) ? (int) $matches[1] : 0;
		
		// OLD index comes from the existing live server root ($rootPath)
		$oldIndexPath = $rootPath . 'index.php';
		if(!file_exists($oldIndexPath)) {
			$this->abort(sprintf($this->_('Required file %s not found.'), 'index.php'));
		}
		$oldIndexData    = (string) file_get_contents($oldIndexPath);
		$oldIndexVersion = preg_match('/define\("PROCESSWIRE", (\d+)\);/', $oldIndexData, $matches) ? (int) $matches[1] : 0;
		
		$indexIsOk = ($newIndexVersion === $oldIndexVersion);

		// --- .htaccess Version Check ---
		// NEW htaccess comes from the freshly extracted zip ($rootTempPath)
		$newHtaccessPath = $rootTempPath . 'htaccess.txt';
		if(!file_exists($newHtaccessPath)) {
			$newHtaccessVersion = 0;
			$newHtaccessData = '';
		} else {
			$newHtaccessData    = (string) file_get_contents($newHtaccessPath);
			$newHtaccessVersion = preg_match('/@htaccessVersion\s+(\d+)/', $newHtaccessData, $matches) ? (int) $matches[1] : 0;
		}
		
		// OLD htaccess comes from the existing live server root ($rootPath)
		$oldHtaccessData    = file_exists($rootPath . '.htaccess') ? (string) file_get_contents($rootPath . '.htaccess') : '';
		$oldHtaccessVersion = preg_match('/@htaccessVersion\s+(\d+)/', $oldHtaccessData, $matches) ? (int) $matches[1] : 0;
		
		$htaccessIsOk = ($newHtaccessVersion === $oldHtaccessVersion);

		$rootWritable = is_writable($rootPath) && is_writable($rootPath . "wire/");

		// determine where we will be moving upgrade files to
		if($rootWritable) {
			// if root path is writable, we can place new dirs/files in the same
			// location as what they are replacing, i.e. /wire/ and /wire-2.5.0/
			$wireNewPath = $rootPath . $wireNewName . "/";
			$htaccessNewFile = $rootPath . $htaccessNewName;
			$indexNewFile = $rootPath . $indexNewName;

		} else {
			// if root is not writable, we will place dirs/files in /site/assets/cache/core-upgrade/ instead.
			$cacheUpgradePath = $this->cachePath;
			$cacheUpgradeURL = str_replace($config->paths->root, '/', $cacheUpgradePath);
			$this->warning(
				sprintf($this->_('The file system is not writable, so files will be installed to %s instead.'), $cacheUpgradeURL) . ' ' .
				$this->_('You will have to copy them manually to your web root.')
			);
			wireMkdir($cacheUpgradePath);
			$wireNewPath = $cacheUpgradePath . 'wire/';
			$htaccessNewFile = $cacheUpgradePath . 'htaccess.txt';
			$indexNewFile = $cacheUpgradePath . 'index.php';
		}

		// renameNow() aborts internally on wire failure (fatal).
		// index.php/htaccess.txt rename failures leave old files in place — safe to continue and clean up temp.
		$this->renameNow($wireTempPath, $wireNewPath);
		$this->renameNow($rootTempPath . "index.php", $indexNewFile, false);
		$this->renameNow($rootTempPath . "htaccess.txt", $htaccessNewFile, false);

		// remove /temp/path/ as no longer needed since we've taken everything we need out of it above
		wireRmdir($this->tempPath, true);

		$wireNewLabel = str_replace($config->paths->root, '/', $wireNewPath);
		$indexNewLabel = $rootWritable ? basename($indexNewFile) : str_replace($config->paths->root, '/', $indexNewFile);
		$htaccessNewLabel = $rootWritable ? basename($htaccessNewFile) : str_replace($config->paths->root, '/', $htaccessNewFile);

		$out =
			$this->h($this->_('Upgrade files copied')) .
			$this->p(
				sprintf(
					$this->_("Copies of the upgrade files have been prepared for installation. At this point, you may install them yourself by replacing the existing `/wire/` directory with `%s`, and optionally `index.php` with `%s`, and `.htaccess` with `%s`."),
					$wireNewLabel,
					$indexNewLabel,
					$htaccessNewLabel
				) . ' ' .
				($rootWritable
					? $this->_('Or, since your file system is writable, this tool can install them.')
					: $this->_('Full instructions are below.'))
			);

		$items = [];

		if($indexIsOk) {
			$items[] = "Your `index.php` file appears to be up-to-date, it should be okay to leave your existing one in place.";
		} else {
			$items[] = "Your `index.php` file appears to need an update, check that you haven’t made any site-specific customizations to it before replacing it.";
		}

		if($htaccessIsOk) {
			$items[] = "Your `.htaccess` file appears to be up-to-date, it should be okay to leave your existing one in place.";
		} else {
			$items[] = "Your `.htaccess` file appears to need an update, check for any site-specific customizations before replacing it. You may want to apply updates to it manually.";
		}

		$out .= $this->ul($items);

		if($rootWritable) {

			$htaccessNote = '';
			if(!$htaccessIsOk) {
				$htaccessNote = $this->_('Since the `.htaccess` file can often have site-specific customizations, it would be best to handle that one manually, unless you know it is unmodified.');
			}

			$out .=
				$this->h($this->_('Want this tool to install the upgrade?')) .
				$this->p(sprintf($this->_("Check the boxes below for what you’d like us to install. %s"), $htaccessNote));

			/** @var InputfieldSubmit $btn */
			$btn = $this->modules->get('InputfieldSubmit');
			$btn->attr('name', 'submit_install');
			$btn->value = $this->_('Install');
			$btn->icon = 'angle-right';

			$out .=
				$this->form('./install/',
					$this->p(
						$this->checkbox('wire', $this->_('Install new core `/wire/` directory'), sprintf($this->_("(old will be renamed to %s)"), "/.wire-$oldVersion/"), true) .
						$this->checkbox('index', $this->_('Install new `index.php` file'), sprintf($this->_("(old will be renamed to %s)"), ".index-$oldVersion.php"), !$indexIsOk) .
						$this->checkbox('htaccess', $this->_('Install new `.htaccess` file'), sprintf($this->_("(old will be renamed to %s)"), ".htaccess-$oldVersion"), false)
					) .
					$this->p($btn->render())
				);

		} else {
			// root not writable

			$backupInfo = [
				"/wire" => "/.wire-$oldVersion",
				"/index.php" => "/.index-$oldVersion.php",
				"/.htaccess" => "/.htaccess-$oldVersion",
			];

			$renameInfo = [
				rtrim($wireNewPath, '/') => "/wire",
				"$indexNewFile" => "/index.php",
				"$htaccessNewFile" => "/.htaccess",
			];

			$out .= $this->p(
				"The file system is not writable, so the upgrade files cannot be installed automatically. " .
				"However, the files are ready for you to move to their destinations."
			);

			$out .=
				$this->h('Backup your existing files') .
				$this->p(
					"While optional, it is strongly recommended to back up all replaced files so they can be restored if needed. " .
					"This can be done using the following file rename operations:"
				);

			$items = [];
			foreach($backupInfo as $old => $new) {
				$items[] = "Rename `$old` to `$new`";
			}
			$out .= $this->ul($items);

			$out .=
				$this->h('Migrate the new files') .
				$this->p('Now you can migrate the new files, renaming them from their temporary location to their destination.');

			$items = [];
			foreach($renameInfo as $old => $new) {
				$old = str_replace($config->paths->root, '/', $old);
				$items[] = "Rename `$old` to `$new`";
			}
			$out .=
				$this->ul($items) .
				$this->p('Once you’ve completed the above steps, your upgrade will be complete.') .
				$this->completionNotes();
		}

		$out .= $this->p('*In many cases, it is not necessary to upgrade the index.php and .htaccess files since they don’t always change between versions.', 'detail');

		return $this->out($out);
	}

	/**
	 * Install prepared files
	 *
	 * @return string Rendered HTML
	 */
	public function executeInstall(): string {
		$this->coreUpgrade();

		$input = $this->input;
		$config = $this->config;

		if(!$input->post('submit_install')) $this->abort($this->_('No form received.'));

		$branch = $this->getBranch();
		if(empty($branch)) $this->abort($this->_('No branch selected.'));

		$oldVersion = $config->version;
		$newVersion = $this->toString($branch['version'] ?? '');
		if($newVersion === '') $this->abort($this->_('No valid branch version selected.'));

		$rootPath = dirname($this->wirePath) . '/';
		$renames = [];
		$selected = [];

		if($input->post('wire')) {
			$renames["wire"] = ".wire-$oldVersion";
			$renames["wire-$newVersion"] = "wire";
			$selected[] = 'wire';
		}
		if($input->post('index')) {
			$renames["index.php"] = ".index-$oldVersion.php";
			$renames["index-$newVersion.php"] = "index.php";
			$selected[] = 'index';
		}
		if($input->post('htaccess')) {
			$renames[".htaccess"] = ".htaccess-$oldVersion";
			$renames["htaccess-$newVersion.txt"] = ".htaccess";
			$selected[] = 'htaccess';
		}

		if(empty($renames)) {
			$this->abort($this->_('No items were selected for installation.'));
		}

		foreach($renames as $old => $new) {
			$this->renameLater($rootPath . $old, $rootPath . $new);
		}

		// Clear the session version cache so the redirect back to ./ picks up the
		// newly installed version from $config->version instead of the stale pre-install data.
		$this->checker->clearVersionsCache();
		$this->log("Core upgrade completed; old=$oldVersion; new=$newVersion; components=" . implode(',', $selected));

		$out =
			$this->h('Upgrade completed') .
			$this->p($this->b('Double check that everything works before you leave this page')) .
			$this->completionNotes();

		return $this->out($out);
	}

	/**
	 * Check if a module path uses symlinks and return its resolved real path.
	 *
	 * This detects both a symlink on the module directory itself and any symlinked
	 * ancestor between /site/modules/ and the module path.
	 * Used by executeModuleDownload() when processWireUpgradePreserveSymlinks is enabled.
	 *
	 * @param string $name Module class name
	 * @return string|false The real (resolved) path if a symlinked path resolves to a directory, false otherwise
	 */
	protected function getSymlinkedModulePath(string $name): string|false {
		$modulePath = rtrim($this->config->paths->siteModules . $name, '/');

		if(!is_link($modulePath)) return false;

		$realPath = realpath($modulePath);
		if($realPath === false || !is_dir($realPath)) {
			$this->warning(sprintf(
				$this->_('Module %s is a symlink but its target could not be resolved — treating as a normal directory.'),
				$name
			), true);
			return false;
		}

		return $realPath;
	}

	/**
	 * Reloads the disk info for a single uninstalled or installed module.
	 * Bypasses the heavy overhead of a global $modules->refresh().
	 *
	 * @param string $name module name (class name)
	 */
	public function refreshSingleModule(string $name): void {
		$info = $this->modules->getModuleInfoVerbose($name, ['forceNew' => true]);

		// Clear SHA baseline so the checker re-establishes it on next run
		$localVersion = $this->toString($info['versionStr'] ?? '');
		if($localVersion !== '') {
			$shaKey = $this->cacheKey('installedSha', $name, $localVersion);
			$this->cache->delete($shaKey);
			$this->debug("Cleared installed SHA baseline; module=$name; version=$localVersion");
		} else {
			$this->log("Could not determine version for $name, SHA baseline not cleared");
		}
	}

	/**
	 * Generates post-upgrade guidance, including verification steps and
	 * instructions for reverting the upgrade if needed.
	 *
	 * @return string Rendered HTML
	 */
	protected function completionNotes(): string {
		$config = $this->config;

		$branch = $this->getBranch();
		if(empty($branch)) return '';

		$newVersion = $branch['version'];
		$oldVersion = $config->version;
		$dbFile = $this->toString($this->session->getFor($this, 'database'));
		$dbNote = '';

		if($dbFile) $dbNote = "Your database was backed up to this file:<br />`$dbFile`";

		$frontEndLink = $this->aa($config->urls->root, 'front-end');
		$adminLink = $this->aa($config->urls->admin, 'admin');
		$items = [];

		$items[] = "Test out both the $frontEndLink and $adminLink of your site in full to make sure everything works.";
		$items[] = "Installed files have permission `$config->chmodFile` and directories `$config->chmodDir`. Double check that these are safe with your web host, especially in a shared hosting environment.";

		if($config->debug) {
			$items[] = "For production sites, remember to turn off debug mode once your upgrade is complete.";
		}

		$out = $this->ul($items);

		$out .=
			$this->p($this->b('If your upgrade did not work…')) .
			$this->p(
				'If you encounter fatal error messages (in the front-end or admin links above), hit reload/refresh in that browser tab until it clears (2-3 times). ' .
				'It may take a few requests for ProcessWire to apply any necessary database schema changes. ' .
				'Should you determine that the upgrade failed for some reason and you want to revert back to the previous version, ' .
				'below are the steps to undo what was just applied.'
			) .
			$this->p('Step 1: Remove the installed updates by renaming or deleting them') .
			$this->ul([
				"Delete `/wire/` directory OR rename it to `/.wire-$newVersion/`",
				"If you replaced the `.htaccess` file: Delete `.htaccess` OR rename it to `.htaccess-$newVersion`",
				"If you replaced the `index.php` file: Delete `index.php` OR rename it to `.index-$newVersion.php`"
			]) .
			$this->p('Step 2: Restore backed up files') .
			$this->ul([
				"Rename directory `/.wire-$oldVersion/` to `/wire/`",
				"If applicable: Rename `.htaccess-$oldVersion` to `.htaccess`",
				"If applicable: Rename `.index-$oldVersion.php` to `index.php`",
			]);

		if($dbNote) $out .=
			$this->p('Step 3: Restore backed up database (if necessary)') .
			$this->ul([$dbNote]);

		return $out;
	}

	/**
	 * Schedule a rename operation, which will occur at __destruct
	 *
	 * @param string $oldPath Current absolute path to the file/directory
	 * @param string $newPath Target absolute path for the rename
	 */
	protected function renameLater(string $oldPath, string $newPath): void {
		// Prevent silent overwrites of scheduled rename operations
		if(isset($this->renames[$oldPath])) {
			$existingNewPath = $this->renames[$oldPath];
			$this->error("Rename collision prevented: '$oldPath' is already scheduled to be renamed to '$existingNewPath'.", true);
			return;
		}

		$this->renames[$oldPath] = $newPath;

		$old = basename(rtrim($oldPath, '/'));
		$new = basename(rtrim($newPath, '/'));
		$this->message("Rename $old => $new");
	}

	/**
	 * Perform a rename now
	 *
	 * @param string $old old file/folder
	 * @param string $new new file/folder
	 * @param bool $required Abort the upgrade if the source file does not exist (default=true)
	 * @throws WireException
	 */
	protected function renameNow(string $old, string $new, bool $required = true): bool {
		// for labels
		$_old = str_starts_with($old, $this->config->paths->root)
			? str_replace($this->config->paths->root, '/', $old)
			: basename(rtrim($old, '/'));
		$_new = str_starts_with($new, $this->config->paths->root)
			? str_replace($this->config->paths->root, '/', $new)
			: basename(rtrim($new, '/'));

		if(!file_exists($old)) {
			if($required) $this->abort(sprintf($this->_('Upgrade aborted. Required file %s does not exist.'), $_old));
			return false;
		}

		if(file_exists($new)) {
			$this->message("$_new already exists (left it untouched)", true);
			return true;
		}

		// files->rename() method will copy the files if rename fails, it will also log errors, since 3.0.178
		$result = $this->files->rename($old, $new);

		if($result) {
			$this->message("Renamed $_old => $_new", true);
			return true;
		} else {
			$this->error(sprintf($this->_('Unable to rename %s to %s'), $_old, $_new), true);
			if(basename(rtrim($new, '/')) === 'wire') {
				$this->abort(sprintf($this->_('Upgrade aborted. Unable to rename %s to %s'), $_old, $_new));
			}
			return false;
		}
	}

	/**
	 * Set the admin page headline to 'Core upgrade'.
	 *
	 * Called by executeCheck(), executeDatabase(), executePrepare(), and executeInstall()
	 * to signal that the user is in the core upgrade workflow.
	 */
	protected function coreUpgrade(): void {
		$this->headline($this->_('Core upgrade'));
	}

	/**
	 * Creates and returns a configured "Refresh" button instance.
	 *
	 * @param bool $showInHeader Whether to display the button in the header (if supported by the Inputfield)
	 * @return InputfieldButton Configured refresh button
	 */
	protected function refreshButton($showInHeader = false): InputfieldButton {
		/** @var InputfieldButton $btn */
		$btn = $this->modules->get('InputfieldButton');
		$btn->href = './refresh';
		$btn->value = $this->_('Refresh Core & Modules List');
		$btn->icon = 'refresh';
		$btn->attr('title', $this->_('Reloads the list of installed modules and core version from disk. Use this if you have added, removed, or updated files manually.'));
		$btn->attr('onclick', "this.querySelector('i').className='fa fa-spinner fa-spin';this.style.pointerEvents='none';this.style.opacity='0.6'");
		if($showInHeader && method_exists($btn, 'showInHeader')) $btn->showInHeader(true);
		return $btn;
	}

	/**
	 * Creates and returns a configured "Check GitHub for Updates" button instance.
	 *
	 * @param bool $showInHeader Whether to display the button in the header (if supported by the Inputfield)
	 * @param string $label Optional custom label
	 * @return InputfieldButton
	 */
	protected function githubCheckButton(bool $showInHeader = false, string $label = ''): InputfieldButton {
		/** @var InputfieldButton $btn */
		$btn = $this->modules->get('InputfieldButton');
		$btn->href = './github-refresh';
		$btn->value = $label !== '' ? $label : $this->_('Check GitHub for Updates');
		$btn->icon = 'github';
		$btn->attr('title', $this->_('Fetches the latest commit and version information for modules and core from GitHub. Use this to check for new releases or updates.'));
		$btn->attr('onclick', "this.querySelector('i').className='fa fa-spinner fa-spin';this.style.pointerEvents='none';this.style.opacity='0.6'");
		if($showInHeader && method_exists($btn, 'showInHeader')) $btn->showInHeader(true);
		return $btn;
	}

	/**
	 * Returns information about the last refresh time and the data source used.
	 *
	 * @param bool $paragraph Whether to wrap the output in a <p> element
	 * @return string HTML with last refresh details
	 */
	protected function lastRefreshInfo(bool $paragraph = true): string {
		$na = $this->_('N/A');
		$sentences = [];

		// Base refresh time
		$lastRefreshRaw = $this->session->getFor($this, 'lastModulesRefreshTime');
		$lastRefreshStr = $this->toString($lastRefreshRaw);
		$lastRefresh = $lastRefreshStr !== '' ? wireRelativeTimeStr($lastRefreshStr) : $na;
		$sentences[] = sprintf($this->_('Last refresh: %s.'), $lastRefresh);

		// GH check time
		if($this->session->getFor($this, 'githubTrackingEnabled')) {
			$githubRefreshRaw = $this->session->getFor($this, 'lastGithubRefreshTime');
			$githubRefreshStr = $this->toString($githubRefreshRaw);
			$githubRefresh = $githubRefreshStr !== '' ? wireRelativeTimeStr($githubRefreshStr) : $na;
			$sentences[] = sprintf($this->_('GitHub check: %s.'), $githubRefresh);
		} else {
			$sentences[] = sprintf($this->_('GitHub check: %s.'), $na);
		}

		// Module repo info
		if($this->checker->useModuleInfoRepo) {
			$sentences[] = $this->_('GitHub checks and links are from module\'s info array.');
		}

		// GH token active
		if($this->toString($this->config->get('githubToken')) !== '') {
			$sentences[] = $this->_('GitHub API Token set.');
		}

		$out = implode(' ', $sentences);

		return $paragraph ? $this->p($out, 'detail last-refresh-info') : $out;
	}

	/**
	 * Process rename operations
	 *
	 * Rename operations are deferred until object destruction to ensure all
	 * file changes occur after the process completes successfully.
	 */
	public function __destruct() {
		if(empty($this->renames)) return;

		// Grab and clear to prevent re-entrant execution loops
		$pendingRenames = $this->renames;
		$this->renames = [];

		$files = $this->files;
		$executed = [];
		$requiresRollback = false;

		foreach($pendingRenames as $oldPath => $newPath) {

			// Handle collision: move existing target out of the way
			if(file_exists($newPath)) {
				$n = 0;
				do {
					$newPath2 = $newPath . "-" . (++$n);
				} while(file_exists($newPath2));

				$this->log("$newPath already exists, renaming it to $newPath2");

				if(!$files->rename($newPath, $newPath2)) {
					$this->error("Unable to move existing $newPath out of the way. Aborting upgrade.", true);
					$requiresRollback = true;
					break;
				}

				// Track sequentially so LIFO order is perfectly preserved
				$executed[] = ['from' => $newPath, 'to' => $newPath2];
			}

			$old = basename(rtrim($oldPath, '/'));
			$new = basename(rtrim($newPath, '/'));

			//MP: heads up: on windows, rename can fail with access denied if folder is locked, eg. explorer is opened in the directory
			//MP: https://github.com/php/php-src/issues/7910
			//MP: https://github.com/ryancramerdesign/ProcessWireUpgrade/issues/31#issuecomment-831190675
			if($files->rename($oldPath, $newPath)) {
				$this->log("Renamed $old => $new");
				$executed[] = ['from' => $oldPath, 'to' => $newPath];
			} else {
				$this->error("Unable to rename $old => $new. Aborting upgrade.", true);
				$requiresRollback = true;
				break;
			}
		}

		// Centralized LIFO rollback execution
		if($requiresRollback && !empty($executed)) {
			$this->error("Initiating rollback sequence...", true);

			foreach(array_reverse($executed) as $op) {
				if($files->rename($op['to'], $op['from'])) {
					$this->log("Rolled back: " . basename($op['to']) . " => " . basename($op['from']));
				} else {
					$this->error("CRITICAL: Rollback failed for {$op['to']}. System may be inconsistent.", true);
				}
			}
		}

	}

	public function h(string $str, int $h = 2): string { return "<h$h>$str</h$h>"; }
	public function p(string $str, string $class = ''): string { return $class ? "<p class='$class'>$str</p>" : "<p>$str</p>"; }
	public function a(string $href, string $label, string $class = ''): string { return ($class ? "<a class='$class' " : "<a ") . "href='" . $this->sanitizer->entities($href) . "'>$label</a>"; }
	public function aa(string $href, string $label, string $class = ''): string { return str_replace('<a', "<a target='_blank'", $this->a($href, $label, $class)); }
	public function span(string $str, string $class = ''): string { return $class ? "<span class='$class'>$str</span>" : "<span>$str</span>"; }
	public function b(string $str, string $class = ''): string { return $class ? "<strong class='$class'>$str</strong>" : "<strong>$str</strong>"; }
	/** @param array<int, string> $items */
	public function ul(array $items): string { return "<ul class='bullets'><li>" . implode('</li><li>', $items) . '</li></ul>'; }
	public function form(string $action, string $content): string { return "<form action='$action' method='post'>$content</form>"; }
	public function icon(string $name, bool $fw = true): string { return wireIconMarkup($name, ($fw ? 'fw' : '')); }
	public function iconLink(string $icon, string $href, string $tooltip): string { return str_replace('<a', "<a title='$tooltip'", $this->aa($href, $this->icon($icon), 'pw-tooltip')); }
	public function tooltip(string $tooltip, string $markup, string $class =''): string { return "<span class='pw-tooltip $class' title='$tooltip'>$markup</span>"; }

	/**
	 * Render a single status pill (count + label) for the stats summary line.
	 *
	 * Zero-count stats render as a quiet outline regardless of category, so a
	 * "0" never competes visually with the real numbers next to it.
	 *
	 * @param int $count
	 * @param string $label Already-translated label text — pass it through $this->_() at the call site
	 * @param bool $actionable
	 * @return string
	 */
	protected function statPill(int $count, string $label, bool $actionable): string {
		if($count === 0) return '';
		$class = ($actionable && $count > 0) ? 'pw-bg-main-color' : 'is-muted';
		return "<span class='stat-pill $class'>$count $label</span>";
	}
	/**
	 * Render the upgrade-summary stats line shown above the table.
	 *
	 * @param array<string, int> $labelCounts Counts gathered in execute()
	 * @return string
	 */
	protected function renderStatsLine(array $labelCounts): string {
		$upToDate = $labelCounts['Up-to-date'] + $labelCounts['Up-to-date+'];
		$pwDebug = $this->config->get('processWireUpgradeDebug');

		$total =
			$labelCounts['Upgrade'] +
			$labelCounts['Download'] +
			$labelCounts['Sync'] +
			$labelCounts['Unavailable'] +
			$upToDate +
			$labelCounts['Managed by'] +
			($labelCounts['LocalOnly'] ?? 0);

		$pills =
			$this->statPill($labelCounts['Upgrade'], $this->_('upgrade'), true) .
			$this->statPill($labelCounts['Download'], $this->_('download'), true) .
			$this->statPill($labelCounts['Sync'], $this->_('sync'), true) .
			$this->statPill($upToDate, $this->_('up-to-date'), false) .
			'';

		if(!empty($pwDebug) && $labelCounts['Managed by'] > 0) {
			$pills .= $this->statPill($labelCounts['Managed by'], $this->_('managed'), false);
		}
		if($labelCounts['Unavailable'] > 0) {
			$pills .= $this->statPill($labelCounts['Unavailable'], $this->_('unavailable'), true);
		}
		if(($labelCounts['LocalOnly'] ?? 0) > 0) {
			$pills .= $this->statPill($labelCounts['LocalOnly'], $this->_('not in directory'), false);
		}
		$pills .= $this->statPill($total, $this->_('total'), false);

		return "<div class='pw-upgrade-stats'>$pills</div>";
	}
	/**
	 * Generates an HTML checkbox input with label and optional note.
	 *
	 * @param string $name Checkbox name attribute
	 * @param string $label Label text displayed next to the checkbox
	 * @param string $note Optional note displayed alongside the label (can contain HTML)
	 * @param bool $checked Whether the checkbox should be pre-checked
	 * @return string Rendered HTML for the checkbox element
	 */
	public function checkbox(string $name, string $label, string $note = '', bool $checked = false): string {
		$adminTheme = $this->wire()->adminTheme;

		$checkboxClass = $this->toString($adminTheme ? $adminTheme->getClass('input-checkbox') : '');
		$checkedAttr = $checked ? ' checked="checked"' : '';

		$safeName  = htmlspecialchars($name, ENT_QUOTES, 'UTF-8');
		$safeLabel = htmlspecialchars($label, ENT_QUOTES, 'UTF-8');
		$noteHtml = $note !== '' ? $this->span($note, 'detail') : '';

		return "<div><label><input type='checkbox' class='$checkboxClass' name='$safeName' value='1'$checkedAttr> $safeLabel $noteHtml</label></div>";
	}

	/**
	 * Replaces backtick-enclosed text with <code> HTML tags.
	 *
	 * Example: `text` becomes <code>text</code>.
	 *
	 * @param string $out Input text
	 */
	protected function out(string $out): string {
		if(!str_contains($out, '`')) return $out;
		$replaced = preg_replace('/`([^<\n`]+?)`/', '<code>$1</code>', $out);
		return is_string($replaced) ? $replaced : $out;
	}

	/**
	 * Install
	 */
	public function ___install(): void {
		$page = new Page();
		$page->template = 'admin';
		$page->name = self::PAGE_NAME;

		// installs to the admin "Setup" menu ... change as you see fit
		//MP: https://github.com/ryancramerdesign/ProcessWireUpgrade/pull/34/commits/9e9f172b348001f6ad2d259dbe7d2d936f7ef2a5
		$page->parent = $this->pages->get($this->config->adminRootPageID)->child('name=setup, include=all');
		$page->process = $this;

		$info = self::getModuleInfo();
		$page->title = $this->toString($info['title'] ?? '');

		$page->save();

		$this->message("Created Page: {$page->path}", true);
	}

	/**
	 * Uninstall
	 */
	public function ___uninstall(): void {
		// find the page we installed, locating it by the process field (which has the module ID)
		// it would probably be sufficient just to locate by name, but this is just to be extra sure.
		$moduleID = $this->modules->getModuleID($this);
		$page = $this->pages->get("template=admin, process=$moduleID, name=" . self::PAGE_NAME . "|core-upgrade");

		if($page->id) {
			$this->message("Deleting Page: {$page->path}", true);
			$page->delete();
		}

		wireRmdir($this->tempPath, true);
		$this->cache->delete(self::CACHE_PREFIX . '*');
		$this->session->removeAllFor('ProcessWireUpgrade');
		$this->session->removeAllFor('ProcessWireUpgradeCheck');
	}

	/**
	 * Upgrade module config
	 *
	 * @param string $fromVersion
	 * @param string $toVersion
	 */
	public function ___upgrade($fromVersion, $toVersion): void {
		// might even be good to clear cache at every upgrade
		//if ((int) $fromVersion <= 14) {
			$this->cache->delete(self::CACHE_PREFIX . '*');
			$this->session->removeAllFor('ProcessWireUpgrade');
			$this->session->removeAllFor('ProcessWireUpgradeCheck');
			$this->message($this->_('Cache and session data for this module cleared.'), true);
		//}
	}

}
